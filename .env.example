# 複製此檔為 .env 並填入實際值
# cp .env.example .env

# PostgreSQL 連線字串
DATABASE_URL=postgresql://cup_user:你的DB密碼@supabase-db:54325/postgres

# Flask（SECRET_KEY 請用隨機長字串，至少 32 個字元）
SECRET_KEY=請換成一個隨機長字串例如openssl-rand-hex-32的輸出
FLASK_ENV=production

# 初始 admin 密碼（僅首次建立 DB 時有效，之後在後台改密碼）
ADMIN_PASSWORD=請設定初始管理員密碼至少12個字元

# AI API Key（選填，可在後台管理介面設定）
GEMINI_API_KEY=你的_Google_Gemini_API_Key
HF_API_KEY=你的_Hugging_Face_Token
